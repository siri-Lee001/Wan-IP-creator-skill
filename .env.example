# 万相API配置
# 请复制此文件为 .env 并填入您的API密钥
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_REGION=beijing  # beijing 或 singapore

# 生图模型配置
IMAGE_MODEL=wan2.7-image
IMAGE_SIZE=2K  # 支持1K、2K（默认），wan2.7-image不支持4K
IMAGE_THINKING_MODE=true
IMAGE_WATERMARK=false

# 视频模型配置
VIDEO_MODEL=wan2.7-i2v
VIDEO_DURATION=5  # 固定5秒
VIDEO_RESOLUTION=720P  # 固定720P
VIDEO_WATERMARK=false
VIDEO_PROMPT_EXTEND=true
VIDEO_THINKING_MODE=true

# 工作流配置
WORKFLOW_MODE=step_by_step  # step_by_step 或 auto
CONFIRM_EACH_IMAGE=true  # 是否每张图确认

# 输出配置
OUTPUT_DIR=./output
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR